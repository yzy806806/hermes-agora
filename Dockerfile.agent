# Agora Agent Container Template
#
# Build: docker build -f Dockerfile.agent -t agora-agent .
# Run:   docker run -e AGORA_COORDINATOR_URL=http://host.docker.internal:8765 \
#          -e AGORA_AGENT_ID=my-agent agora-agent
#
# Customize by overriding CMD with your agent logic.

FROM python:3.12-slim

WORKDIR /app

# Install runtime dependencies
RUN pip install --no-cache-dir \
    httpx>=0.27 aiohttp>=3.9 websockets>=12.0 \
    pydantic>=2.0 pydantic-settings>=2.0

# Copy agora package (includes agent_client)
COPY agora/ /app/agora/
COPY pyproject.toml README.md ./

# Install project (no deps — already installed above)
RUN pip install --no-deps -e .

# Agent configuration via environment
ENV AGORA_COORDINATOR_URL=http://coordinator:8765
ENV AGORA_AGENT_ID=agent-1
ENV AGORA_LOG_LEVEL=info

# Default: run agent client connecting to coordinator
CMD ["agora-agent"]
